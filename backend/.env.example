# Cadena de conexión a MongoDB
MONGO_URI=mongodb://localhost:27017/bd_fce_graph

# Puerto donde corre el servidor Flask
PORT=5000

# "development" habilita el modo debug de Flask
FLASK_ENV=development

# Orígenes permitidos para CORS, separados por coma.
# En producción, reemplazar "*" por el/los dominios reales del frontend.
ORIGENES_PERMITIDOS=*
